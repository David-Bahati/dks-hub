
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSeller() {
      return isSignedIn() && exists(/databases/$(database)/documents/sellers/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isSeller();
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(adminId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /sellers/{sellerId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(sellerId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }

    match /customers/{customerId} {
      allow get, list, create, update, delete: if isStaff();
    }

    match /paymentModes/{paymentModeId} {
      allow get, list: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    // Unified Rules for Orders and Sales
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow list: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow create: if isStaff();
      allow list, get: if isStaff();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /sales/{saleId}/saleItems/{saleItemId} {
      allow list, get: if isStaff();
      allow create, update, delete: if isStaff();
    }

    match /carts/{userId} {
      allow get, write: if isOwner(userId);
    }
  }
}
