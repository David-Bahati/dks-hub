
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSeller() {
      return isSignedIn() && exists(/databases/$(database)/documents/sellers/$(request.auth.uid));
    }

    function isCashier() {
      return isSignedIn() && exists(/databases/$(database)/documents/cashiers/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isSeller() || isCashier();
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isOwner(adminId) || isAdmin();
    }

    match /sellers/{sellerId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isOwner(sellerId) || isAdmin();
    }

    match /cashiers/{cashierId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isOwner(cashierId) || isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /customers/{customerId} {
      allow read, write: if isStaff();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && (isStaff() || resource.data.userId == request.auth.uid);
      // Correction cruciale pour le listage des commandes
      allow list: if isSignedIn() && (isStaff() || request.auth.uid == resource.data.userId);
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow create: if isStaff();
      allow read: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
