rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a robust Role-Based Access Control (RBAC) system using "Existence-Based 
     * Authorization" (DBAC). Permissions are derived from the presence of a user's UID in 
     * specialized role collections (/admins or /sellers).
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSeller() {
      return isSignedIn() && exists(/databases/$(database)/documents/sellers/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isSeller();
      allow list: if isAdmin() || isSeller();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow self-creation for bootstrapping
      allow create: if isOwner(adminId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /sellers/{sellerId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow self-creation for bootstrapping
      allow create: if isOwner(sellerId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() || isSeller();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() || isSeller();
    }

    match /customers/{customerId} {
      allow get, list, create, update, delete: if isAdmin() || isSeller();
    }

    match /paymentModes/{paymentModeId} {
      allow get, list: if isAdmin() || isSeller();
      allow create, update, delete: if isAdmin();
    }

    // Orders and Sales (Unified Rules)
    // We allow users to list their own orders by checking resource.data.userId
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow get, list: if isAdmin() || isSeller() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || isSeller();
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow create: if isSignedIn();
      allow get, list: if isAdmin() || isSeller() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || isSeller();
      allow delete: if isAdmin();
    }

    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get, list, create: if isSignedIn() && (isAdmin() || isSeller() || resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() || isSeller();
    }

    match /carts/{userId} {
      allow get, write: if isOwner(userId);
    }
  }
}