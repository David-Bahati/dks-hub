
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTION DE BASE ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- RÈGLES ULTRA-SIMPLIFIÉES (MODE DÉPANNAGE) ---
    // On autorise TOUT à TOUT utilisateur connecté pour débloquer l'application.
    
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
