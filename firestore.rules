
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSeller() {
      return isSignedIn() && exists(/databases/$(database)/documents/sellers/$(request.auth.uid));
    }

    function isCashier() {
      return isSignedIn() && exists(/databases/$(database)/documents/cashiers/$(request.auth.uid));
    }

    function isStaff() {
      // Un utilisateur est staff s'il existe dans l'une des collections de rôles
      return isAdmin() || isSeller() || isCashier();
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == adminId);
    }

    match /sellers/{sellerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == sellerId);
    }

    match /cashiers/{cashierId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == cashierId);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /customers/{customerId} {
      allow read, write: if isStaff();
    }

    match /orders/{orderId} {
      // Un client peut créer une commande s'il est connecté
      allow create: if isSignedIn();
      
      // Lecture d'une commande unique
      allow get: if isSignedIn() && (isStaff() || resource.data.userId == request.auth.uid);
      
      // Pour lister les commandes, Firestore exige que la requête soit filtrée par userId si l'utilisateur n'est pas staff
      allow list: if isSignedIn() && (isStaff() || (resource.data.userId == request.auth.uid));
      
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow create: if isStaff();
      allow read: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
