rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a robust Role-Based Access Control (RBAC) system using "Existence-Based 
     * Authorization" (DBAC). Instead of checking fields within a user document, permissions are derived 
     * from the presence of a user's UID in specialized role collections (/admins or /sellers).
     *
     * BOOTSTRAP MODE:
     * To allow initial setup from the client, we allow users to create their own role document 
     * if it matches their UID.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSeller() {
      return isSignedIn() && exists(/databases/$(database)/documents/sellers/$(request.auth.uid));
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId); // Simplified for prototype
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow self-creation for bootstrapping the first admin
      allow create: if isOwner(adminId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /sellers/{sellerId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow self-creation for bootstrapping or admin assignment
      allow create: if isOwner(sellerId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() || isSeller();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() || isSeller();
    }

    match /customers/{customerId} {
      allow get, list, create, update, delete: if isAdmin() || isSeller();
    }

    match /paymentModes/{paymentModeId} {
      allow get, list: if isAdmin() || isSeller();
      allow create, update, delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow get: if isAdmin() 
        || (resource.data.sellerId == request.auth.uid) 
        || (resource.data.customerId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isAdmin() || isSeller();
      allow update: if isAdmin() || (resource != null && resource.data.sellerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get: if isAdmin() 
        || (resource.data.sellerId == request.auth.uid) 
        || (resource.data.customerId == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isAdmin() || isSeller();
      allow update: if isAdmin() || (resource != null && resource.data.sellerId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}