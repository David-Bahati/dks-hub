
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE BASE ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Vérifie si l'utilisateur a un rôle de staff (casse flexible)
    function isStaff() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc != null && (
        userDoc.data.role.lower() == 'admin' || 
        userDoc.data.role.lower() == 'seller' || 
        userDoc.data.role.lower() == 'cashier' ||
        userDoc.data.role.lower() == 'vendeur' ||
        userDoc.data.role.lower() == 'caissier'
      );
    }

    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc != null && userDoc.data.role.lower() == 'admin';
    }

    // --- RÈGLES PAR COLLECTION ---

    // Notifications : Autorise la lecture à tout utilisateur connecté pour éviter les crashs
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isStaff();
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn(); // Simplifié pour éviter les erreurs de listing
      allow update: if isStaff();
    }

    match /sales/{saleId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
