
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && data != null && (data.role == 'Admin' || data.role == 'admin');
    }

    function isStaff() {
      let data = getUserData();
      return isSignedIn() && data != null && (
        data.role == 'Admin' || data.role == 'admin' || 
        data.role == 'Seller' || data.role == 'seller' || 
        data.role == 'Cashier' || data.role == 'cashier'
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isStaff();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && (isStaff() || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (isStaff() || (resource.data.userId == request.auth.uid));
    }

    match /notifications/{notifId} {
      // Un utilisateur peut lire ses propres notifications ou celles destinées au staff s'il est staff
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.userId == 'staff' ||
        isStaff()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.userId == 'staff' ||
        isStaff()
      );
      allow delete: if isStaff();
    }

    match /sales/{saleId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
