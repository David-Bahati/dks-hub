
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Récupère les données de l'utilisateur actuel pour vérifier son rôle
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }

    function isStaff() {
      return isSignedIn() && (
        getUserData().role == 'Admin' || 
        getUserData().role == 'Seller' || 
        getUserData().role == 'Cashier'
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isStaff(); // Seul le staff peut lister tous les utilisateurs
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId) || isStaff();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /orders/{orderId} {
      // Un client peut créer une commande
      allow create: if isSignedIn();
      // Un utilisateur peut lire sa propre commande, ou le staff peut tout lire
      allow get: if isSignedIn() && (isStaff() || resource.data.userId == request.auth.uid);
      // Pour lister, le client doit obligatoirement filtrer par son propre userId
      allow list: if isSignedIn() && (isStaff() || (request.query.limit <= 100 && request.auth.uid == request.query.filters.userId));
    }

    match /sales/{saleId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Compatibilité avec les anciennes collections de rôles si nécessaire
    match /admins/{id} { allow read: if isSignedIn(); }
    match /sellers/{id} { allow read: if isSignedIn(); }
    match /cashiers/{id} { allow read: if isSignedIn(); }
  }
}
