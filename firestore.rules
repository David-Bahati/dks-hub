
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FONCTIONS DE VÉRIFICATION ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Vérifie si l'utilisateur a un rôle de staff (Admin, Seller, Cashier)
    function isStaff() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc != null && (
        userDoc.data.role == 'Admin' || userDoc.data.role == 'admin' || 
        userDoc.data.role == 'Seller' || userDoc.data.role == 'seller' || 
        userDoc.data.role == 'Cashier' || userDoc.data.role == 'cashier'
      );
    }

    // Vérifie si l'utilisateur est Admin
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc != null && (
        userDoc.data.role == 'Admin' || userDoc.data.role == 'admin'
      );
    }

    // --- RÈGLES PAR COLLECTION ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isStaff();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      // Un utilisateur peut voir ses commandes, le staff peut tout voir
      allow read: if isSignedIn() && (
        isStaff() || 
        resource.data.userId == request.auth.uid
      );
    }

    match /notifications/{notifId} {
      // Règle de lecture optimisée pour les requêtes "in" et les accès directs
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.userId == 'staff' ||
        isStaff()
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isStaff()
      );
      allow delete: if isStaff();
    }

    match /sales/{saleId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
