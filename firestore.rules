rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read/write access to the "products" collection for any signed-in user.
    // In a real production app, you'd likely have more granular rules,
    // for example, only allowing specific admin users to write.
    match /products/{productId} {
      allow read, write: if request.auth != null;
    }

    // Users can read and update their own document.
    // Creation of a user document is handled by the registration logic (server-side or trusted client).
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Placeholder for future collections (e.g., orders)
    // match /orders/{orderId} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
