
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      let role = getUserData().role;
      return isSignedIn() && (role == 'Admin' || role == 'admin');
    }

    function isStaff() {
      let role = getUserData().role;
      return isSignedIn() && (
        role == 'Admin' || role == 'admin' || 
        role == 'Seller' || role == 'seller' || 
        role == 'Cashier' || role == 'cashier'
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isStaff();
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId) || isStaff();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && (isStaff() || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (isStaff() || resource.data.userId == request.auth.uid);
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'staff');
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'staff');
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /admins/{id} { allow read: if isSignedIn(); }
    match /sellers/{id} { allow read: if isSignedIn(); }
    match /cashiers/{id} { allow read: if isSignedIn(); }
  }
}
