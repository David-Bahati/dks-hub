
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSeller() {
      return isSignedIn() && exists(/databases/$(database)/documents/sellers/$(request.auth.uid));
    }

    function isCashier() {
      return isSignedIn() && exists(/databases/$(database)/documents/cashiers/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isSeller() || isCashier();
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isStaff();
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sellers/{sellerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /cashiers/{cashierId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /orders/{orderId} {
      // Autoriser la création pour tout utilisateur connecté
      allow create: if isSignedIn();
      
      // Autoriser la lecture individuelle si propriétaire ou staff
      allow read: if isSignedIn() && (isStaff() || resource.data.userId == request.auth.uid);
      
      // Simplification du listage pour éviter les erreurs de permission
      // Le filtrage se fait par la requête client (where userId == uid)
      allow list: if isSignedIn();
    }

    match /sales/{saleId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /customers/{customerId} {
      allow read, write: if isStaff();
    }
  }
}
