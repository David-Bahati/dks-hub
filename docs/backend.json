
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the ShopManager application with specific roles and access permissions.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["Admin", "Seller", "Cashier", "customer"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "role",
        "createdAt",
        "updatedAt"
      ]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a customer order placed through the store.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string",
          "description": "The UID of the customer who placed the order."
        },
        "customerName": {
          "type": "string"
        },
        "items": {
          "type": "array"
        },
        "total": {
          "type": "number"
        },
        "paymentMethod": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents an item available for sale.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "sellingPrice": {
          "type": "number"
        },
        "stockQuantity": {
          "type": "number"
        },
        "imageUrl": {
          "type": "string",
          "format": "uri"
        },
        "isPublished": {
          "type": "boolean"
        }
      },
      "required": ["id", "name", "sellingPrice", "stockQuantity"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/admins/{adminId}": {
      "schema": "User",
      "description": "Admin role assignment."
    },
    "/sellers/{sellerId}": {
      "schema": "User",
      "description": "Seller role assignment."
    },
    "/cashiers/{cashierId}": {
      "schema": "User",
      "description": "Cashier role assignment."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Hardware products inventory."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/sales/{saleId}": {
      "schema": "Order",
      "description": "POS sales records."
    },
    "/carts/{userId}": {
      "schema": "object",
      "description": "User shopping carts."
    }
  }
}
