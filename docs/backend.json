
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the ShopManager application with specific roles and access permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Seller", "Cashier", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order placed through the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents an item available for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "sellingPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "isPublished": { "type": "boolean" }
      },
      "required": ["id", "name", "sellingPrice", "stockQuantity"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Represents a technical support or warranty claim.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "productName": { "type": "string" },
        "issueDescription": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "diagnosing", "repairing", "ready", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productName", "issueDescription", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user alerts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Recipient ID (or 'staff' for all employees)" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string" }
      },
      "required": ["userId", "title", "message", "isRead", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com", "github.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Hardware products inventory."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/supportTickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Technical support tickets and warranty claims."
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "System notifications."
    },
    "/sales/{saleId}": {
      "schema": "object",
      "description": "POS sales records."
    },
    "/system/{docId}": {
      "schema": "object",
      "description": "Global shop configuration (exchange rates, etc.)"
    }
  }
}
