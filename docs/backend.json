
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the ShopManager application with specific roles and access permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Seller", "Cashier", "customer"] },
        "loyaltyLevel": { "type": "string", "enum": ["Bronze", "Silver", "Gold"] },
        "points": { "type": "number", "description": "Accumulated prestige points" },
        "tokenBalance": { "type": "number", "description": "DKST Token balance" },
        "pointsConverted": { "type": "number", "description": "Points already turned into tokens" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "updatedAt"]
    },
    "TokenTransaction": {
      "title": "TokenTransaction",
      "description": "Represents a point-to-token conversion or token usage.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["mint", "burn", "transfer"] },
        "pointsAmount": { "type": "number" },
        "tokenAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "tokenAmount", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order placed through the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents an item available for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "sellingPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "isPublished": { "type": "boolean" }
      },
      "required": ["id", "name", "sellingPrice", "stockQuantity"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Represents a technical support or warranty claim.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "productName": { "type": "string" },
        "issueDescription": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "diagnosing", "repairing", "ready", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "imageUrl": { "type": "string", "description": "Optional photo of the issue." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productName", "issueDescription", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com", "github.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/tokenTransactions/{txId}": {
      "schema": "TokenTransaction",
      "description": "Prestige point conversions."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Hardware products inventory."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/supportTickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Technical support tickets."
    }
  }
}
