
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the ShopManager application with specific roles and access permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Seller", "Cashier", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order placed through the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents an item available for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "sellingPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "isPublished": { "type": "boolean" }
      },
      "required": ["id", "name", "sellingPrice", "stockQuantity"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/admins/{adminId}": {
      "schema": "object",
      "description": "Admin role assignment."
    },
    "/sellers/{sellerId}": {
      "schema": "object",
      "description": "Seller role assignment."
    },
    "/cashiers/{cashierId}": {
      "schema": "object",
      "description": "Cashier role assignment."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Hardware products inventory."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/sales/{saleId}": {
      "schema": "object",
      "description": "POS sales records."
    },
    "/carts/{userId}": {
      "schema": "object",
      "description": "User shopping carts."
    }
  }
}
