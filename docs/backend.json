
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the ShopManager application with specific roles and access permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Seller", "Cashier", "customer"] },
        "loyaltyLevel": { "type": "string", "enum": ["Bronze", "Silver", "Gold"] },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order placed through the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents an item available for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "sellingPrice": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "isPublished": { "type": "boolean" }
      },
      "required": ["id", "name", "sellingPrice", "stockQuantity"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Represents a technical support or warranty claim.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "productName": { "type": "string" },
        "issueDescription": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "diagnosing", "repairing", "ready", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "imageUrl": { "type": "string", "description": "Optional photo of the issue." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productName", "issueDescription", "status", "createdAt"]
    },
    "HardwareAsset": {
      "title": "HardwareAsset",
      "description": "Un appareil appartenant à un client enregistré dans le Hub pour suivi.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "specs": { "type": "string" },
        "status": { "type": "string", "enum": ["excellent", "good", "warning", "repair_needed"] },
        "lastMaintenance": { "type": "string", "format": "date-time" }
      }
    },
    "TechnicalAudit": {
      "title": "TechnicalAudit",
      "description": "A professional technical audit request for business infrastructure.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "businessName": { "type": "string" },
        "contactPerson": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "needs": { "type": "array" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "scheduled", "completed", "cancelled"] },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "reportUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "businessName", "phone", "status", "createdAt"]
    },
    "Consumable": {
      "title": "Consumable",
      "description": "Lab maintenance resources like thermal paste, solder, etc.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "minThreshold": { "type": "number" },
        "unitCost": { "type": "number", "description": "Unit cost for stock valuation" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "quantity", "unit", "minThreshold"]
    },
    "LabTool": {
      "title": "LabTool",
      "description": "Équipement de laboratoire nécessitant un suivi d'usure (ex: Fer à souder, Station air chaud).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "serialNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["excellent", "good", "warning", "service_needed"] },
        "usageCount": { "type": "number" },
        "usageThreshold": { "type": "number" },
        "lastMaintenance": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status", "usageCount", "usageThreshold"]
    },
    "TechnicianLog": {
      "title": "TechnicianLog",
      "description": "Journal de bord quotidien du laboratoire pour les observations techniques et passations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "technical", "incident", "handover"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "content", "type", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com", "github.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Hardware products inventory."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/supportTickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Technical support tickets."
    },
    "/hardwareAssets/{assetId}": {
      "schema": "HardwareAsset",
      "description": "Client hardware park."
    },
    "/audits/{auditId}": {
      "schema": "TechnicalAudit",
      "description": "Business infrastructure audits."
    },
    "/consumables/{consumableId}": {
      "schema": "Consumable",
      "description": "Lab consumables."
    },
    "/labTools/{toolId}": {
      "schema": "LabTool",
      "description": "Lab tools tracking."
    },
    "/technicianLogs/{logId}": {
      "schema": "TechnicianLog",
      "description": "Lab daily logbook."
    }
  }
}
