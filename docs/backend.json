
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the ShopManager application with specific roles and access permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "description": "URL of the profile picture" },
        "role": { "type": "string", "enum": ["Admin", "Seller", "Cashier", "customer"] },
        "loyaltyLevel": { "type": "string", "enum": ["Bronze", "Silver", "Gold"] },
        "kycStatus": { "type": "string", "enum": ["none", "pending", "verified", "rejected"] },
        "kycDocumentType": { "type": "string" },
        "kycDocumentNumber": { "type": "string" },
        "kycDocumentImage": { "type": "string" },
        "kycSelfieImage": { "type": "string" },
        "kycSubmittedAt": { "type": "string", "format": "date-time" },
        "kycVerifiedAt": { "type": "string", "format": "date-time" },
        "points": { "type": "number" },
        "tokenBalance": { "type": "number" },
        "stakedBalance": { "type": "number" },
        "piWalletAddress": { "type": "string" },
        "walletPin": { "type": "string" },
        "isWalletLocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "updatedAt"]
    },
    "Treasury": {
      "title": "Treasury",
      "description": "Global company wallet storing all currencies and tracking revenue sources.",
      "type": "object",
      "properties": {
        "dkstBalance": { "type": "number" },
        "piBalance": { "type": "number" },
        "usdBalance": { "type": "number" },
        "cdfBalance": { "type": "number" },
        "totalMinted": { "type": "number" },
        "lastReconciliationAt": { "type": "string", "format": "date-time" }
      }
    },
    "TokenTransaction": {
      "title": "TokenTransaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["mint", "burn", "transfer", "mining", "staking", "unstaking", "exchange", "heritage", "dividend"] },
        "tokenAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com", "github.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User"
    },
    "/system/treasury": {
      "schema": "Treasury"
    },
    "/tokenTransactions/{txId}": {
      "schema": "TokenTransaction"
    }
  }
}
