
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the ShopManager application with specific roles and access permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Seller", "Cashier", "customer"] },
        "loyaltyLevel": { "type": "string", "enum": ["Bronze", "Silver", "Gold"] },
        "points": { "type": "number", "description": "Accumulated prestige points" },
        "tokenBalance": { "type": "number", "description": "DKST Token balance" },
        "stakedBalance": { "type": "number", "description": "Amount of DKST currently staked" },
        "stakingStartedAt": { "type": "string", "format": "date-time" },
        "pointsConverted": { "type": "number", "description": "Points already turned into tokens" },
        "piWalletAddress": { "type": "string", "description": "Public address on the Pi blockchain" },
        "lastMiningAt": { "type": "string", "format": "date-time" },
        "miningPower": { "type": "number" },
        "completedMissionsToday": { "type": "array", "items": { "type": "string" } },
        "lastBlockRarity": { "type": "string", "enum": ["common", "rare", "legendary"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "updatedAt"]
    },
    "TokenTransaction": {
      "title": "TokenTransaction",
      "description": "Represents a point-to-token conversion, token usage on the Pi blockchain, or mining reward.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["mint", "burn", "transfer", "mining", "staking", "unstaking", "exchange"] },
        "pointsAmount": { "type": "number" },
        "tokenAmount": { "type": "number" },
        "piTxId": { "type": "string", "description": "Pi Blockchain transaction hash" },
        "direction": { "type": "string", "enum": ["sent", "received"] },
        "memo": { "type": "string" },
        "rarity": { "type": "string", "enum": ["common", "rare", "legendary"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "tokenAmount", "createdAt"]
    },
    "HallOfFameEntry": {
        "title": "HallOfFameEntry",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "userId": { "type": "string" },
            "userName": { "type": "string" },
            "title": { "type": "string" },
            "period": { "type": "string" },
            "achievement": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" }
        }
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com", "github.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/tokenTransactions/{txId}": {
      "schema": "TokenTransaction",
      "description": "Prestige point conversions and mining events."
    },
    "/hallOfFame/{id}": {
        "schema": "HallOfFameEntry",
        "description": "Historical records of DKS champions."
    }
  }
}
